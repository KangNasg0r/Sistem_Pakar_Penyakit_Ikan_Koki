	<parameter name="ADMIN" class="java.lang.String"/>
	<parameter name="TGL_AWAL" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="TGL_AKHIR" class="java.util.Date">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="PERIODE" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT 
    d.id_diagnosa,
    d.nama_ikan,
    d.tanggal_diagnosa,
    d.hasil_diagnosa,
    d.solusi,
    GROUP_CONCAT(
        CONCAT(dd.kode_gejala, ' - ', g.nama_gejala)
        ORDER BY dd.kode_gejala ASC
        SEPARATOR '\n'
    ) AS fakta_gejala
FROM diagnosa d
LEFT JOIN diagnosa_detail dd ON d.id_diagnosa = dd.id_diagnosa
LEFT JOIN gejala g ON dd.kode_gejala = g.kode_gejala
WHERE d.tanggal_diagnosa BETWEEN $P{TGL_AWAL} AND $P{TGL_AKHIR}
GROUP BY 
    d.id_diagnosa,
    d.nama_ikan,
    d.tanggal_diagnosa,
    d.hasil_diagnosa,
    d.solusi
ORDER BY d.tanggal_diagnosa DESC, d.id_diagnosa DESC]]>
	</queryString>
